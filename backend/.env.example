# Copy this file to .env and fill in only what you have.
# The app works fully for free with NONE of these set.

# --- Optional: smarter script/scene planning via Claude ---
# Get one at https://console.anthropic.com (paid, pay-per-use)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Optional: real stock footage instead of generated placeholders ---
# Free tier: https://www.pexels.com/api/  (200 req/hour, 20000/month free)
PEXELS_API_KEY=
# Free tier: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# --- Optional: paid text-to-video generation hook ---
# Leave blank to use free stock/AI-image visuals instead.
# TEXT_TO_VIDEO_PROVIDER=runway
# TEXT_TO_VIDEO_API_KEY=

# --- Server ---
ENV=development
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# --- TTS voice default (edge-tts is free, no key needed) ---
DEFAULT_TTS_ENGINE=edge-tts
DEFAULT_VOICE=en-US-AriaNeural

# --- Captioning model size: tiny|base|small|medium (bigger=slower, more accurate) ---
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
